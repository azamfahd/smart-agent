  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "esbuild": "^0.28.0",
    "tsx": "^4.22.4",
    "typescript": "^5.5.3",
    "vite": "^5.4.1"
  }
}
